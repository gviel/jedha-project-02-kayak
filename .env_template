# Pipeline configuration
CRON_SCHEDULE="0 6 * * *"   # heure UTC : 06:00 prod | ex. test 19h30 CEST = "30 17 * * *"
TOP_N_CITIES=5               # nombre de villes top à scraper (hotels)
TOP_N_HOTELS=20              # nombre max d'hôtels affichés par ville (UI + BDD)

# OpenWeatherMap API
API_KEY_OWM="<your-openweathermap-api-key>"

# AWS S3
AWS_DOMAIN="amazonaws.com"
AWS_REGION="eu-west-3"
AWS_IAM_PERSON="<iam-user-name>"
AWS_ACCESS_KEY_ID="<your-aws-access-key-id>"
AWS_SECRET_ACCESS_KEY="<your-aws-secret-access-key>"
S3_BUCKET="<your-s3-bucket-name>"

# PgSQL instance
## NEON DB
PGHOST='<your-neon-host>.aws.neon.tech'
PGDATABASE='<your-neon-database>'
PGUSER='<your-neon-user>'
PGPASSWORD='<your-neon-password>'
PGSSLMODE='require'
PGCHANNELBINDING='require'
DATABASE_URL='postgresql://<PGUSER>:<PGPASSWORD>@<PGHOST>/<PGDATABASE>?sslmode=require&channel_binding=require'

## AWS RDS (alternative)
#PG_USERNAME="postgres"
#PG_PWD="<your-rds-password>"
#DB_IDENTIFIER="<your-rds-instance-identifier>"
#DB_SUBDOMAIN="<your-rds-subdomain>"
# DB_HOST = {DB_ID}.{DB_SUBDOMAIN}.{AWS_REGION}.rds.{AWS_DOMAIN}
# PostgreSQL — construit depuis PG_USERNAME/PG_PWD/DB_IDENTIFIER/DB_SUBDOMAIN/AWS_REGION/AWS_DOMAIN
#DATABASE_URL="postgresql://<PG_USERNAME>:<PG_PWD>@<DB_IDENTIFIER>.<DB_SUBDOMAIN>.<AWS_REGION>.rds.<AWS_DOMAIN>:5432/postgres"
